{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "if": "Write(**/travel-guide.html)",
            "command": "node \"$CLAUDE_PROJECT_DIR/.claude/hooks/approval-gate-guard.js\"",
            "statusMessage": "Checking traveler approval gate..."
          },
          {
            "type": "command",
            "if": "Write(**/travel-guide.html)",
            "command": "node \"$CLAUDE_PROJECT_DIR/.claude/hooks/no-leak-guard.js\"",
            "statusMessage": "Scanning for internal-artifact leakage..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "if": "Write(**/trips/**)",
            "command": "node \"$CLAUDE_PROJECT_DIR/.claude/hooks/post-write-state.js\"",
            "statusMessage": "Syncing workflow-state.json..."
          },
          {
            "type": "command",
            "if": "Edit(**/trips/**)",
            "command": "node \"$CLAUDE_PROJECT_DIR/.claude/hooks/post-write-state.js\"",
            "statusMessage": "Syncing workflow-state.json..."
          }
        ]
      }
    ]
  },
  "enabledMcpjsonServers": ["open-meteo"]
}
